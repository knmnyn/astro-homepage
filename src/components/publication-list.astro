---
import SectionMetrics from "./section-metrics.astro";
import CardTitleLink from "./card-title-link.astro";
import CardUrlLinks from "./card-url-links.astro";
import { buildSheetMetrics, buildMetricCardData, getSheetCountMetric } from "../lib/sheet-metrics";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";

const {
  id,
  title,
  summary,
  kicker = "",
  intro = "",
  trailer = "",
  items = [],
  sheet = null,
  scope = id,
  showExtras = false,
  masonryGrid = false,
  emptyMessage = "No publications are available yet.",
} = Astro.props;

const metrics = buildSheetMetrics(sheet);
const countMetric = getSheetCountMetric(metrics);
const records = Array.isArray(sheet?.records) ? sheet.records : [];

function joinParts(values, separator = " · ") {
  return values.filter(Boolean).join(separator);
}

function formatVolumeIssue(volume, issue) {
  if (volume && issue) {
    return `${volume} (${issue})`;
  }

  return volume || issue || "";
}

---

<section id={id} class="panel section-block publication-list" data-metric-scope-root={scope}>
  <div class="section-header">
    <div>
      {kicker || countMetric ? (
        <p
          class="section-kicker"
          set:html={renderInlineMarkdown([kicker, countMetric ? countMetric.value : ""].filter(Boolean).join(" · "))}
        ></p>
      ) : null}
      <h2>{title}</h2>
    </div>
    <div class="section-header-aside">
      {summary && <p class="section-summary">{summary}</p>}
      {intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(intro)}></span>}
      <SectionMetrics metrics={metrics} scope={scope} />
    </div>
  </div>

  {items.length > 0 ? (
    <div class={`publication-grid ${masonryGrid ? "publication-grid--masonry" : "publication-grid--stack"}`}>
      {items.map((item, index) => {
        const metricValues = buildMetricCardData(records[index], metrics);

        return (
          <article
            class={`publication-card ${showExtras ? "publication-card--full" : "publication-card--compact"}`}
            data-metric-card
            data-metric-values={JSON.stringify(metricValues)}
          >
            <div class="list-meta">
              <span>{item.year || "n.d."}</span>
              {item.type && <span>{item.type}</span>}
              {item.area && <span>{item.area}</span>}
              {showExtras && item.status && <span>{item.status}</span>}
              {showExtras && item.award && <span>{item.award}</span>}
            </div>

            <CardTitleLink title={item.title || "Untitled"} url={item.url || ""} />

            <p>{item.authors}</p>

            <p class="muted">
              {joinParts(
                showExtras
              ? [item.venue, formatVolumeIssue(item.volume, item.issue), item.pages, item.notes]
              : [item.venue, item.pages, item.notes],
              )}
            </p>
            <CardUrlLinks links={item.links} />
          </article>
        );
      })}
    </div>
  ) : (
    <p class="empty-state">{emptyMessage}</p>
  )}

  {trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(trailer)}></span>}
</section>

<style>
  .publication-list {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .publication-grid {
    display: grid;
    gap: 0.85rem;
  }

  .publication-grid--masonry {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
  }

  .publication-grid--stack {
    grid-template-columns: 1fr;
  }

  .section-header-aside {
    display: grid;
    gap: 0.6rem;
    justify-items: end;
  }

  .section-copy {
    display: block;
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.96rem;
  }

  .section-copy--intro {
    text-align: right;
  }

  .section-copy--trailer {
    margin-top: 1.15rem;
    font-size: 0.9rem;
    font-style: italic;
  }

  .publication-card {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .publication-card h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .publication-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .publication-card--compact {
    padding: 0.9rem 0.95rem;
  }

  .list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .list-meta span + span::before {
    content: "•";
    margin-right: 0.45rem;
  }

  .muted,
  .empty-state {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .section-header-aside {
      justify-items: start;
    }

    .section-copy--intro {
      text-align: left;
    }

    .publication-grid--masonry {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .publication-grid--masonry {
      grid-template-columns: 1fr;
    }
  }
</style>
