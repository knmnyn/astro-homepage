---
const {
  items = [],
  ariaLabel = "Section navigation",
  themeLabel = "Color theme",
  themeGroupLabel = "Color theme mode",
  fontSizeLabel = "Text size",
} = Astro.props;

const currentPathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const normalizePathname = (href) => new URL(href, Astro.url).pathname.replace(/\/$/, "") || "/";
---

<nav class="section-nav panel" aria-label={ariaLabel} data-open="false">
  <div class="section-nav-bar">
    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="section-nav-links"
      aria-label="Open navigation menu"
    >
      <span class="nav-toggle-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span class="nav-toggle-label">Menu</span>
    </button>

    <div class="section-nav-controls">
      <div class="theme-switch" aria-label={themeLabel}>
        <span class="sr-only">{themeLabel}</span>
        <div class="theme-switch-group" role="group" aria-label={themeGroupLabel}>
          <button type="button" class="theme-switch-option" data-theme-choice="auto" aria-pressed="true" aria-label="Use system theme">
            <span aria-hidden="true">◌</span>
          </button>
          <button type="button" class="theme-switch-option" data-theme-choice="light" aria-pressed="false" aria-label="Use light theme">
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                <circle cx="12" cy="12" r="4.5" />
                <path d="M12 2.5v2.2M12 19.3v2.2M4.7 4.7l1.6 1.6M17.7 17.7l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.7 19.3l1.6-1.6M17.7 6.3l1.6-1.6" />
              </svg>
            </span>
          </button>
          <button type="button" class="theme-switch-option" data-theme-choice="dark" aria-pressed="false" aria-label="Use dark theme">
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                <path d="M20.2 14.8A7.8 7.8 0 1 1 9.2 3.8a8.7 8.7 0 1 0 11 11z" />
              </svg>
            </span>
          </button>
        </div>
      </div>

      <label class="font-scale" aria-label={fontSizeLabel}>
        <span class="sr-only">{fontSizeLabel}</span>
        <select data-font-scale-choice>
          <option value="80">80%</option>
          <option value="100" selected>100%</option>
          <option value="120">120%</option>
        </select>
      </label>
    </div>
  </div>

  <div id="section-nav-links" class="section-nav-links" aria-label={ariaLabel}>
    {items.map((item) => {
      const isActive = normalizePathname(item.href) === currentPathname;

      return (
        <a href={item.href} title={item.title} aria-current={isActive ? "page" : undefined}>
          {item.label}
        </a>
      );
    })}
  </div>

  <script is:inline>
    (() => {
      const nav = document.currentScript?.closest(".section-nav");
      const toggle = nav?.querySelector(".nav-toggle");
      if (!nav || !toggle) return;

      const setOpen = (open) => {
        nav.dataset.open = String(open);
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
      };

      toggle.addEventListener("click", () => {
        setOpen(nav.dataset.open !== "true");
      });

      const media = window.matchMedia("(min-width: 721px)");
      const syncLayout = () => {
        if (media.matches) {
          setOpen(false);
        }
      };

      media.addEventListener("change", syncLayout);
      syncLayout();
    })();
  </script>
</nav>

<style>
  .section-nav {
    position: fixed;
    top: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    width: min(1140px, calc(100% - 1rem));
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 0.9rem;
    border-radius: 22px;
    background: var(--nav-panel);
    border: 1px solid var(--nav-border);
    box-shadow: var(--nav-shadow);
    backdrop-filter: blur(18px);
  }

  .section-nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: nowrap;
    min-width: 0;
    order: 2;
    flex: 0 0 auto;
  }

  .section-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    order: 1;
    flex: 1 1 auto;
    min-width: 0;
  }

  .section-nav a {
    border-radius: 999px;
    border: 1px solid transparent;
    background: var(--nav-chip);
    padding: 0.5rem 0.8rem;
    text-decoration: none;
    color: var(--muted);
    font-weight: 700;
    font-size: 0.9rem;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease,
      background-color 160ms ease;
  }

  .section-nav a[aria-current="page"] {
    color: var(--accent);
    border-color: var(--line-strong);
    background: color-mix(in srgb, var(--accent-soft) 68%, var(--nav-chip));
  }

  .section-nav a:hover {
    color: var(--accent-2);
    transform: translateY(-1px);
  }

  .section-nav-controls {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: nowrap;
    justify-content: flex-end;
    min-width: 0;
  }

  .nav-toggle {
    display: none;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    background: var(--nav-chip);
    color: var(--muted);
    font-weight: 700;
    cursor: pointer;
  }

  .nav-toggle-icon {
    display: inline-grid;
    gap: 0.18rem;
  }

  .nav-toggle-icon span {
    display: block;
    width: 1rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .theme-switch {
    display: flex;
    align-items: center;
  }

  .theme-switch-group {
    display: inline-flex;
    gap: 0.2rem;
    padding: 0.2rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--nav-chip);
  }

  .theme-switch-option {
    border: 0;
    border-radius: 999px;
    width: 1.9rem;
    height: 1.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .theme-switch-option svg {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-switch-option[aria-pressed="true"] {
    background: var(--control-active);
    color: var(--control-active-text);
    box-shadow: 0 10px 20px color-mix(in srgb, var(--control-active) 24%, transparent);
  }

  .theme-switch-option:hover {
    transform: translateY(-1px);
  }

  .font-scale select {
    min-width: 4.9rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--nav-chip);
    color: var(--muted);
    font: inherit;
    font-weight: 700;
    padding: 0.38rem 0.62rem;
  }

  .font-scale select:focus-visible {
    outline-offset: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 980px) {
    .section-nav {
      width: min(100% - 1rem, 1140px);
    }
  }

  @media (max-width: 720px) {
    .section-nav {
      top: 0.5rem;
      width: min(100% - 0.5rem, 1140px);
      padding: 0.65rem 0.7rem;
      border-radius: 18px;
      align-items: stretch;
      flex-wrap: wrap;
    }

    .nav-toggle {
      display: inline-flex;
      gap: 0.4rem;
      padding: 0.4rem 0.6rem;
    }

    .section-nav-bar {
      align-items: center;
      gap: 0.45rem;
      width: 100%;
      order: 1;
    }

    .section-nav-controls {
      margin-left: auto;
      gap: 0.4rem;
    }

    .section-nav-links {
      display: none;
      width: 100%;
      padding-top: 0.75rem;
      border-top: 1px solid var(--line);
      order: 2;
    }

    .section-nav[data-open="true"] .section-nav-links {
      display: grid;
    }

    .section-nav[data-open="true"] .section-nav-links a {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    .font-scale {
      flex: 1 1 auto;
    }

    .font-scale select {
      width: auto;
      min-width: 4.4rem;
      max-width: 5.3rem;
      padding: 0.34rem 0.5rem;
      text-align: center;
    }

    .nav-toggle-label {
      display: none;
    }
  }
</style>
