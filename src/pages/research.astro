---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import CardTitleLink from "../components/card-title-link.astro";
import CardUrlLinks from "../components/card-url-links.astro";
import StudentCard from "../components/student-card.astro";
import SectionMetrics from "../components/section-metrics.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { getNavSectionText, primaryNavItems } from "../lib/site-navigation";
import { sortTalkItems } from "../lib/talk-order.js";
import { sitePath } from "../lib/site-path";
import { buildSheetMetrics, buildMetricCardData, getSheetCountMetric } from "../lib/sheet-metrics";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";
import { isFeaturedTalkCard } from "../lib/url-links.js";

const profile = siteData.profile;
const softwareItems = siteData.software;
const studentItems = siteData.students;
const talkItems = siteData.talks;
const grantItems = siteData.grants;
const softwareRecords = Array.isArray(siteData.sources.software?.records) ? siteData.sources.software.records : [];
const studentRecords = Array.isArray(siteData.sources.students?.records) ? siteData.sources.students.records : [];
const talkRecords = Array.isArray(siteData.sources.talks?.records) ? siteData.sources.talks.records : [];
const grantRecords = Array.isArray(siteData.sources.grants?.records) ? siteData.sources.grants.records : [];
const softwareTags = [...new Set(softwareItems.flatMap((item) => String(item.tags || "").split(/\s*,\s*/).filter(Boolean)))];
const publicationAreas = [...new Set(siteData.publications.map((item) => item.area).filter(Boolean))];
const latestSoftware = softwareItems[0] || {};
const latestStudent = studentItems[0] || {};
const sortedTalkItems = sortTalkItems(talkItems);
const latestTalk = sortedTalkItems[0] || {};
const latestGrant = grantItems[0] || {};
const softwareMetrics = buildSheetMetrics(siteData.sources.software);
const studentMetrics = buildSheetMetrics(siteData.sources.students);
const talkMetrics = buildSheetMetrics(siteData.sources.talks);
const grantMetrics = buildSheetMetrics(siteData.sources.grants);
const softwareCountMetric = getSheetCountMetric(softwareMetrics);
const studentCountMetric = getSheetCountMetric(studentMetrics);
const talkCountMetric = getSheetCountMetric(talkMetrics);
const grantCountMetric = getSheetCountMetric(grantMetrics);
const researchText = getNavSectionText("research", { kicker: "Research" });
const softwareText = getNavSectionText("software", { kicker: "Software" });
const studentsText = getNavSectionText("students", {
  kicker: "Students",
  header: "Students",
  summary: "Current student cohort",
  intro: "Students are grouped by role for a tighter scan of the roster.",
  trailer: "The full cohort appears above.",
});
const talksText = getNavSectionText("talks", { kicker: "Talks" });
const grantsText = getNavSectionText("grants", { kicker: "Grants" });

function studentGroupLabel(role = "") {
  const normalized = String(role).toLowerCase();
  if (normalized.includes("doctoral")) {
    return "Doctoral Students";
  }
  if (normalized.includes("master")) {
    return "Master Students";
  }
  if (normalized.includes("urop") || normalized.includes("fyp") || normalized.includes("undergraduate") || normalized.includes("cp")) {
    return "Undergraduate Students";
  }
  return role || "Students";
}

const studentGroups = Array.from(
  studentItems.reduce((map, item) => {
    const label = studentGroupLabel(item.role);
    const group = map.get(label) || [];
    group.push(item);
    map.set(label, group);
    return map;
  }, new Map()),
).map(([label, items]) => ({ label, items }));

const footerLinks = [
  {
    href: sitePath("publications/"),
    label: "Publications archive",
    title: "Browse the full publications page",
  },
  {
    href: sitePath("misc/"),
    label: "Misc archive",
    title: "Browse the service and personal link archive",
  },
];
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Research`}
  description={`Research overview for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Research overview"
      title={profile.name || "Min-Yen Kan"}
      headline="Featured publications stay on the homepage, while the full software inventory now lives here."
      tags={[
        `${siteData.publications.length} publications`,
        `${softwareItems.length} software items`,
        `${studentItems.length} students`,
        profile.title,
      ].filter(Boolean)}
      stats={[
        {
          label: "Software items",
          value: softwareItems.length,
          text: latestSoftware.name || "No software records yet",
        },
        {
          label: "Topics",
          value: softwareTags.length || "—",
          text: softwareTags.join(" · ") || "Tags appear here as the sheet grows.",
        },
        {
          label: "Latest student",
          value: latestStudent.title || "—",
          text: [latestStudent.role, latestStudent.status].filter(Boolean).join(" · ") || "Student record",
        },
        {
          label: "Latest talk",
          value: latestTalk.date || latestTalk.year || "—",
          text: latestTalk.title || "Talk record",
        },
        {
          label: "Latest grant",
          value: latestGrant.startYear || "—",
          text: latestGrant.title || "Grant record",
          accent: true,
        },
      ]}
    />

    <SectionNav items={primaryNavItems} />

    <section id="overview" class="section-intro panel">
      <p class="section-kicker" set:html={renderInlineMarkdown(researchText.kicker)}></p>
      <h2>{researchText.header}</h2>
      {researchText.summary && <p class="section-summary" set:html={renderInlineMarkdown(researchText.summary)}></p>}
      <p>
        The sheet-driven site keeps the homepage compact while still reflecting the structure
        of the original website: research-oriented publications, current students, course
        history, software, service, talks, grants, and personal links.
      </p>
      {researchText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(researchText.intro)}></span>}
      <div class="tag-row">
        {publicationAreas.map((area) => <span>{area}</span>)}
      </div>
      {researchText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(researchText.trailer)}></span>}
    </section>

    <section id="software" class="panel section-block" data-metric-scope-root="research-software">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(`${softwareText.kicker || ""}${softwareCountMetric ? ` · ${softwareCountMetric.value}` : ""}`)}></p>
          <h2>{softwareText.header}</h2>
        </div>
        <div class="section-header-aside">
          {softwareText.summary && <p class="section-summary" set:html={renderInlineMarkdown(softwareText.summary)}></p>}
          {softwareText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(softwareText.intro)}></span>}
          <SectionMetrics metrics={softwareMetrics} scope="research-software" />
        </div>
      </div>

      <div class="stack">
        {softwareItems.map((item, index) => (
          <article class="list-item" data-metric-card data-metric-values={JSON.stringify(buildMetricCardData(softwareRecords[index], softwareMetrics))}>
            <div class="list-meta">
              {item.status && <span>{item.status}</span>}
              {item.tags && <span>{item.tags}</span>}
            </div>
            <CardTitleLink title={item.name || "Software"} url={item.url || ""} />
            <p class="muted">{item.description}</p>
            <CardUrlLinks links={item.links} />
          </article>
        ))}
      </div>
      {softwareText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(softwareText.trailer)}></span>}
    </section>

    <section id="students" class="panel section-block" data-metric-scope-root="research-students">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(`${studentsText.kicker || ""}${studentCountMetric ? ` · ${studentCountMetric.value}` : ""}`)}></p>
          <h2>{studentsText.header}</h2>
        </div>
        <div class="section-header-aside">
          {studentsText.summary && <p class="section-summary" set:html={renderInlineMarkdown(studentsText.summary)}></p>}
          {studentsText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(studentsText.intro)}></span>}
          <SectionMetrics metrics={studentMetrics} scope="research-students" />
        </div>
      </div>

      <div class="student-groups">
        {studentGroups.map((group) => (
          <section class="student-group">
            <h3>{group.label}</h3>
            <div class="student-grid">
              {group.items.map((item) => {
                const index = studentItems.indexOf(item);
                return (
                  <StudentCard
                    title={item.title || "Student"}
                    role={item.role || ""}
                    avatar={item.avatar || ""}
                    url={item.url || ""}
                    cohort={item.cohort || ""}
                    level={item.level || ""}
                    status={item.status || ""}
                    interests={item.interests || ""}
                    data-metric-card
                    data-metric-values={JSON.stringify(buildMetricCardData(studentRecords[index], studentMetrics))}
                  />
                );
              })}
            </div>
          </section>
        ))}
      </div>
      {studentsText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(studentsText.trailer)}></span>}
    </section>

    <section id="talks" class="panel section-block" data-metric-scope-root="research-talks">
      <div class="section-header">
        <div>
          <p
            class="section-kicker"
            set:html={renderInlineMarkdown(talksText.header ? `${talksText.kicker || ""}${talkCountMetric ? ` · ${talkCountMetric.value}` : ""}` : "")}
          ></p>
          <h2>{talksText.header}</h2>
        </div>
        <div class="section-header-aside">
          {talksText.summary && <p class="section-summary" set:html={renderInlineMarkdown(talksText.summary)}></p>}
          {talksText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(talksText.intro)}></span>}
          <SectionMetrics metrics={talkMetrics} scope="research-talks" />
        </div>
      </div>

      <div class="talk-grid">
        {sortedTalkItems.map((item, index) => (
          <article
            class={`list-item talk-card ${isFeaturedTalkCard(item) ? "talk-card--featured" : ""}`.trim()}
            data-metric-card
            data-metric-values={JSON.stringify(
              buildMetricCardData(talkRecords[item.sourceIndex] ?? talkRecords[index] ?? {}, talkMetrics),
            )}
          >
            <div class="list-meta">
              {item.role && <span>{item.role}</span>}
              {item.recordType && <span>{item.recordType}</span>}
            </div>
            <p class="card-topline">
              {item.date || item.year || "n.d."}
              {item.location ? ` · ${item.location}` : ""}
            </p>
            <CardTitleLink title={item.title || "Talk"} url={item.url || ""} />
            <p>{[item.event, item.venue].filter(Boolean).join(" · ")}</p>
            {item.notes && <p class="muted">{item.notes}</p>}
            <CardUrlLinks links={item.links} />
          </article>
        ))}
      </div>
      {talksText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(talksText.trailer)}></span>}
    </section>

    <section id="grants" class="panel section-block" data-metric-scope-root="research-grants">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(`${grantsText.kicker || ""}${grantCountMetric ? ` · ${grantCountMetric.value}` : ""}`)}></p>
          <h2>{grantsText.header}</h2>
        </div>
        <div class="section-header-aside">
          {grantsText.summary && <p class="section-summary" set:html={renderInlineMarkdown(grantsText.summary)}></p>}
          {grantsText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(grantsText.intro)}></span>}
          <SectionMetrics metrics={grantMetrics} scope="research-grants" />
        </div>
      </div>

      <div class="stack">
        {grantItems.map((item, index) => (
          <article class="list-item" data-metric-card data-metric-values={JSON.stringify(buildMetricCardData(grantRecords[index], grantMetrics))}>
            <p class="card-topline">
              {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
              {item.recordType ? ` · ${item.recordType}` : ""}
            </p>
            <CardTitleLink title={item.title || "Grant"} url={item.url || ""} />
            <p>{[item.role, item.sponsor].filter(Boolean).join(" · ")}</p>
            {item.amount && <p class="muted">{`${item.currency || ""} ${item.amount}`.trim()}</p>}
            {item.notes && <p class="muted">{item.notes}</p>}
            <CardUrlLinks links={item.links} />
          </article>
        ))}
      </div>
      {grantsText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(grantsText.trailer)}></span>}
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .section-intro {
    border-radius: 26px;
    padding: 1.25rem;
    display: grid;
    gap: 0.85rem;
  }

  .section-intro h2 {
    margin: 0.2rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .section-block {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .stack {
    display: grid;
    gap: 0.85rem;
  }

  .student-groups {
    display: grid;
    gap: 1.2rem;
  }

  .student-group {
    display: grid;
    gap: 0.75rem;
  }

  .student-group h3 {
    margin: 0;
    letter-spacing: -0.02em;
    font-size: 1.05rem;
  }

  .student-grid {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .talk-grid {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .talk-card--featured {
    grid-column: 1 / -1;
  }

  .section-header-aside {
    display: grid;
    gap: 0.6rem;
    justify-items: end;
  }

  .list-item {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .list-item h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .list-meta,
  .section-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent-2);
    font-weight: 700;
  }

  .list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .list-meta span + span::before {
    content: "•";
    margin-right: 0.45rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .section-summary,
  .list-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .card-topline {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent-2);
    font-weight: 700;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .section-header-aside {
      justify-items: start;
    }

    .student-grid {
      grid-template-columns: 1fr;
    }

    .talk-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block {
      border-radius: 20px;
      padding: 1rem;
    }
  }
</style>
