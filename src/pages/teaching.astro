---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import SectionMetrics from "../components/section-metrics.astro";
import CardTitleLink from "../components/card-title-link.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { getNavSectionText, primaryNavItems } from "../lib/site-navigation";
import { sitePath } from "../lib/site-path";
import { buildSheetMetrics, buildMetricCardData, getSheetCountMetric } from "../lib/sheet-metrics";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";

const profile = siteData.profile;
const teachingItems = siteData.teaching;
const teachingRecords = Array.isArray(siteData.sources.teaching?.records) ? siteData.sources.teaching.records : [];
const teachingYears = [...new Set(teachingItems.map((item) => item.academicYear).filter(Boolean))];
const latestTeaching = teachingItems[0] || {};
const teachingMetrics = buildSheetMetrics(siteData.sources.teaching);
const teachingCountMetric = getSheetCountMetric(teachingMetrics);
const teachingText = getNavSectionText("teaching", { kicker: "Teaching" });

const navItems = primaryNavItems;

const footerLinks = [
  {
    href: sitePath(""),
    label: "Back home",
    title: "Return to the homepage",
  },
  {
    href: sitePath("misc/"),
    label: "Misc archive",
    title: "Browse the service and personal link archive",
  },
];
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Teaching`}
  description={`Teaching archive for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Teaching archive"
      title={profile.name || "Min-Yen Kan"}
      headline="A complete list of teaching and facilitation entries from the sheet."
      tags={[
        `${teachingItems.length} teaching entries`,
        `${teachingYears.length || "No"} academic years`,
        profile.title,
      ].filter(Boolean)}
      stats={[
        {
          label: "Latest entry",
          value: latestTeaching.academicYear || "n.d.",
          text: latestTeaching.courseTitle || "Teaching record",
        },
        {
          label: "Sections",
          value: latestTeaching.section || "—",
          text: latestTeaching.role || "Role not specified",
          accent: true,
        },
      ]}
    />

    <SectionNav items={navItems} />

    <section class="panel section-block" data-metric-scope-root="teaching-archive">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(`${teachingText.kicker || ""}${teachingCountMetric ? ` · ${teachingCountMetric.value}` : ""}`)}></p>
          <h2>{teachingText.header}</h2>
        </div>
        <div class="section-header-aside">
          {teachingText.summary && <p class="section-summary" set:html={renderInlineMarkdown(teachingText.summary)}></p>}
          <SectionMetrics metrics={teachingMetrics} scope="teaching-archive" />
        </div>
      </div>

      {teachingText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(teachingText.intro)}></span>}

      <div class="stack">
        {teachingItems.map((item, index) => (
          <article class="list-item" data-metric-card data-metric-values={JSON.stringify(buildMetricCardData(teachingRecords[index], teachingMetrics))}>
            <p class="card-topline">
              {item.academicYear || "n.d."}
              {item.term ? ` · ${item.term}` : ""}
            </p>
            <CardTitleLink
              title={`${item.courseCode ? `${item.courseCode} ` : ""}${item.courseTitle || "Course"}`}
              url={item.url || ""}
            />
            <p>{[item.role, item.level, item.section].filter(Boolean).join(" · ")}</p>
            {item.notes && <p class="muted">{item.notes}</p>}
          </article>
        ))}
      </div>

      {teachingText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(teachingText.trailer)}></span>}
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .section-block {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .stack {
    display: grid;
    gap: 0.85rem;
  }

  .section-header-aside {
    display: grid;
    gap: 0.6rem;
    justify-items: end;
  }

  .list-item {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .list-item h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .card-topline,
  .section-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent-2);
    font-weight: 700;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .section-summary,
  .list-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .section-header-aside {
      justify-items: start;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block {
      border-radius: 20px;
      padding: 1rem;
    }
  }
</style>
