---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import SectionMetrics from "../components/section-metrics.astro";
import CardTitleLink from "../components/card-title-link.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { getNavSectionText, primaryNavItems } from "../lib/site-navigation";
import { sitePath } from "../lib/site-path";
import { buildSheetMetrics, buildMetricCardData, getSheetCountMetric } from "../lib/sheet-metrics";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";

const profile = siteData.profile;
const serviceItems = siteData.service;
const serviceRecords = Array.isArray(siteData.sources.service?.records) ? siteData.sources.service.records : [];
const serviceCategories = [...new Set(serviceItems.map((item) => item.category).filter(Boolean))];
const latestService = serviceItems[0] || {};
const featuredService = serviceItems.slice(0, 4);
const serviceMetrics = buildSheetMetrics(siteData.sources.service);
const serviceCountMetric = getSheetCountMetric(serviceMetrics);
const serviceText = getNavSectionText("service", { kicker: "Service" });

const navItems = primaryNavItems;

const footerLinks = [
  {
    href: sitePath(""),
    label: "Back home",
    title: "Return to the homepage",
  },
  {
    href: sitePath("misc/"),
    label: "Misc archive",
    title: "Browse the service and personal link archive",
  },
];
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Service`}
  description={`Service archive for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Service overview"
      title={profile.name || "Min-Yen Kan"}
      headline="A compact service overview. The full archive now lives on the misc page."
      tags={[
        `${serviceItems.length} service entries`,
        `${serviceCategories.length || "No"} categories`,
        profile.title,
      ].filter(Boolean)}
      stats={[
        {
          label: "Latest entry",
          value: latestService.startYear || "n.d.",
          text: latestService.organization || "Service record",
        },
        {
          label: "Category",
          value: latestService.category || "—",
          text: latestService.role || "Role not specified",
          accent: true,
        },
      ]}
    />

    <SectionNav items={navItems} />

    <section class="panel section-block" data-metric-scope-root="service-archive">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(`${serviceText.kicker || ""}${serviceCountMetric ? ` · ${serviceCountMetric.value}` : ""}`)}></p>
          <h2>{serviceText.header}</h2>
        </div>
        <div class="section-header-aside">
          {serviceText.summary && <p class="section-summary" set:html={renderInlineMarkdown(serviceText.summary)}></p>}
          <SectionMetrics metrics={serviceMetrics} scope="service-archive" />
        </div>
      </div>

      {serviceText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(serviceText.intro)}></span>}

      <div class="stack">
        {featuredService.map((item, index) => (
          <article class="list-item" data-metric-card data-metric-values={JSON.stringify(buildMetricCardData(serviceRecords[index], serviceMetrics))}>
            <p class="card-topline">
              {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
              {item.category ? ` · ${item.category}` : ""}
            </p>
            <CardTitleLink title={[item.role, item.organization].filter(Boolean).join(" · ") || "Service"} url={item.url || ""} />
            <p class="muted">{item.description}</p>
          </article>
        ))}
      </div>

      {serviceText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(serviceText.trailer)}></span>}
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .section-block {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .stack {
    display: grid;
    gap: 0.85rem;
  }

  .section-header-aside {
    display: grid;
    gap: 0.6rem;
    justify-items: end;
  }

  .list-item {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .list-item h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .card-topline,
  .section-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent-2);
    font-weight: 700;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .section-summary,
  .list-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .section-header-aside {
      justify-items: start;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block {
      border-radius: 20px;
      padding: 1rem;
    }
  }
</style>
