---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { primaryNavItems } from "../lib/site-navigation";
import { sitePath } from "../lib/site-path";

const profile = siteData.profile;
const serviceItems = siteData.service;
const personalLinks = siteData.personalLinks;
const serviceCategories = [...new Set(serviceItems.map((item) => item.category).filter(Boolean))];
const personalCategories = [...new Set(personalLinks.map((item) => item.category).filter(Boolean))];
const latestService = serviceItems[0] || {};

const footerLinks = [
  {
    href: sitePath("service/"),
    label: "Service overview",
    title: "Browse the service summary page",
  },
  {
    href: sitePath("research/"),
    label: "Research page",
    title: "Browse the research overview",
  },
];
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Miscellaneous`}
  description={`Miscellaneous archive for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Miscellaneous archive"
      title={profile.name || "Min-Yen Kan"}
      headline="Service records and the old personal links now live together here."
      tags={[
        `${serviceItems.length} service entries`,
        `${personalLinks.length} personal links`,
        profile.title,
      ].filter(Boolean)}
      stats={[
        {
          label: "Service entries",
          value: serviceItems.length,
          text: latestService.organization || "No service records yet",
        },
        {
          label: "Categories",
          value: serviceCategories.length + personalCategories.length || "—",
          text: [...serviceCategories, ...personalCategories].join(" · ") || "Categories appear here as the sheet grows.",
          accent: true,
        },
      ]}
    />

    <SectionNav items={primaryNavItems} />

    <section id="service" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker">Service</p>
          <h2>Full service archive</h2>
        </div>
        <p class="section-summary">The comprehensive service listing now lives in the miscellaneous area.</p>
      </div>

      <div class="stack">
        {serviceItems.map((item) => (
          <article class="list-item">
            <p class="card-topline">
              {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
              {item.category ? ` · ${item.category}` : ""}
            </p>
            <h3>{[item.role, item.organization].filter(Boolean).join(" · ")}</h3>
            <p class="muted">{item.description}</p>
            {item.url && (
              <a class="inline-link" href={item.url} rel="noreferrer">
                Related site
              </a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="personal" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker">Miscellaneous</p>
          <h2>Personal links</h2>
        </div>
        <p class="section-summary">The old personal page links are grouped here for easy browsing.</p>
      </div>

      <div class="card-grid">
        {personalLinks.map((item) => (
          <article class="info-card">
            <p class="card-topline">{item.category || "link"}</p>
            <h3>
              {item.url ? (
                <a href={item.url} rel="noreferrer">
                  {item.label || "Link"}
                </a>
              ) : (
                item.label || "Link"
              )}
            </h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .section-block {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .stack,
  .card-grid {
    display: grid;
    gap: 0.85rem;
  }

  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .list-item,
  .info-card {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .info-card {
    padding: 0.9rem 0.95rem;
  }

  .list-item h3,
  .info-card h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .card-topline,
  .section-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent-2);
    font-weight: 700;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .section-summary,
  .list-item p,
  .info-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .inline-link {
    display: inline-flex;
    margin-top: 0.6rem;
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .inline-link:hover {
    color: var(--accent-2);
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block {
      border-radius: 20px;
      padding: 1rem;
    }
  }
</style>
