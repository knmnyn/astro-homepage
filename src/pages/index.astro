---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import PublicationList from "../components/publication-list.astro";
import CardTitleLink from "../components/card-title-link.astro";
import CardUrlLinks from "../components/card-url-links.astro";
import StudentCard from "../components/student-card.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { getNavSectionText, primaryNavItems } from "../lib/site-navigation";
import { sitePath } from "../lib/site-path";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";
import { isFeaturedTalkCard } from "../lib/url-links.js";

const profile = siteData.profile;

const bioLines = String(profile.bio_md || "")
  .split(/\n+/)
  .map((line) => line.trim())
  .filter(Boolean);

const publicationAreas = [...new Set(siteData.publications.map((item) => item.area).filter(Boolean))];
const featuredPublications = siteData.publications.slice(0, 6);
const currentTeaching = siteData.teaching.slice(0, 4);
const featuredStudents = siteData.students.filter((item) => item.status !== "archived").slice(0, 6);
const featuredTalks = siteData.talks.slice(0, 4);
const featuredGrants = siteData.grants.slice(0, 4);
const featuredSoftware = siteData.software.filter((item) => item.featured === "yes" || item.featured === "Yes");
const featuredService = siteData.service.slice(0, 4);
const featuredLinks = siteData.personalLinks.filter((item) => item.featured === "yes" || item.featured === "Yes");
const sectionNavItems = primaryNavItems;
const researchText = getNavSectionText("research", { kicker: "Research" });
const teachingText = getNavSectionText("teaching", { kicker: "Teaching" });
const studentsText = getNavSectionText("students", {
  kicker: "Students",
  header: "Students",
  summary: "Current student cohort",
  intro: "Selected active students from the sheet.",
  trailer: "The cohort list is grouped below by role.",
});
const softwareText = getNavSectionText("software", { kicker: "Software" });
const talksText = getNavSectionText("talks", { kicker: "Talks" });
const grantsText = getNavSectionText("grants", { kicker: "Grants" });
const serviceText = getNavSectionText("service", { kicker: "Service" });
const miscText = getNavSectionText("misc", { kicker: "Misc" });
const publicationsText = getNavSectionText("publications", { kicker: "Publications" });

const footerLinks = [
  {
    href: sitePath("publications/"),
    label: "Publications archive",
    title: "Browse the full publications page",
  },
];

const contactItems = [
  profile.email && { label: "Email", value: profile.email, href: `mailto:${profile.email}` },
  profile.cv_url && { label: "CV", value: "Curriculum Vitae", href: profile.cv_url },
  profile.office && { label: "Office", value: profile.office },
  profile.address && { label: "Address", value: profile.address },
].filter(Boolean);
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Homepage`}
  description={`Homepage for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Computer Science · Natural Language Processing · Information Retrieval"
      title={profile.name}
      headline={`${profile.title}${profile.role ? ` · ${profile.role}` : ""}`}
      body={bioLines}
      contacts={contactItems}
    />

    <SectionNav items={sectionNavItems} />

    <section id="research" class="content-grid">
      <div class="section-intro panel">
        <p class="section-kicker" set:html={renderInlineMarkdown(researchText.kicker)}></p>
        <h2>{researchText.header}</h2>
        {researchText.summary && <p class="section-summary" set:html={renderInlineMarkdown(researchText.summary)}></p>}
        <p>
          The sheet-driven site keeps the homepage compact while still reflecting the structure
          of the original website: research-oriented publications, current students, course
          history, software, service, talks, grants, and personal links.
        </p>
        {researchText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(researchText.intro)}></span>}
        <div class="tag-row">
          {publicationAreas.map((area) => <span>{area}</span>)}
        </div>
        {researchText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(researchText.trailer)}></span>}
      </div>

      <PublicationList
        id="featured-publications"
        title={publicationsText.header}
        summary={publicationsText.summary}
        kicker={publicationsText.kicker}
        intro={publicationsText.intro}
        trailer={publicationsText.trailer}
        items={featuredPublications}
      />
    </section>

    <section id="teaching" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(teachingText.kicker)}></p>
          <h2>{teachingText.header}</h2>
        </div>
        {teachingText.summary && <p class="section-summary" set:html={renderInlineMarkdown(teachingText.summary)}></p>}
      </div>
      {teachingText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(teachingText.intro)}></span>}
      <div class="card-grid">
        {currentTeaching.map((item) => (
          <article class="info-card">
            <p class="card-topline">
              {item.academicYear || "n.d."}
              {item.term ? ` · ${item.term}` : ""}
            </p>
            <CardTitleLink
              title={`${item.courseCode ? `${item.courseCode} ` : ""}${item.courseTitle || "Course"}`}
              url={item.url || ""}
            />
            <p>{[item.role, item.level, item.section].filter(Boolean).join(" · ")}</p>
            <CardUrlLinks links={item.links} />
            {item.notes && <p class="muted">{item.notes}</p>}
          </article>
          ))}
      </div>
      {teachingText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(teachingText.trailer)}></span>}
    </section>

    <section class="dual-grid">
      <div id="students" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker" set:html={renderInlineMarkdown(studentsText.kicker)}></p>
            <h2>{studentsText.header}</h2>
          </div>
        </div>
        {studentsText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(studentsText.intro)}></span>}
        <div class="student-grid">
          {featuredStudents.map((item) => (
            <StudentCard
              title={item.title || "Student"}
              role={item.role || ""}
              avatar={item.avatar || ""}
              url={item.url || ""}
              cohort={item.cohort || ""}
              level={item.level || ""}
              status={item.status || ""}
              interests={item.interests || ""}
            />
          ))}
        </div>
        {studentsText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(studentsText.trailer)}></span>}
      </div>

      <div id="software" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker" set:html={renderInlineMarkdown(softwareText.kicker)}></p>
            <h2>{softwareText.header}</h2>
          </div>
          {softwareText.summary && <p class="section-summary" set:html={renderInlineMarkdown(softwareText.summary)}></p>}
        </div>
        {softwareText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(softwareText.intro)}></span>}
        <div class="stack">
          {featuredSoftware.map((item) => (
            <article class="list-item compact">
              <CardTitleLink title={item.name || "Software"} url={item.url || ""} />
              <p>{item.description}</p>
              <p class="muted">{item.tags}</p>
              <CardUrlLinks links={item.links} />
            </article>
          ))}
        </div>
        {softwareText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(softwareText.trailer)}></span>}
      </div>
    </section>

    <section class="tri-grid">
      <div id="talks" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker" set:html={renderInlineMarkdown(talksText.kicker)}></p>
            <h2>{talksText.header}</h2>
          </div>
        </div>
        {talksText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(talksText.intro)}></span>}
        <div class="talk-grid">
          {featuredTalks.map((item) => (
            <article class={`info-card compact talk-card ${isFeaturedTalkCard(item) ? "talk-card--featured" : ""}`.trim()}>
              <p class="card-topline">
                {item.date || item.year || "n.d."}
                {item.location ? ` · ${item.location}` : ""}
              </p>
              <CardTitleLink title={item.title || "Talk"} url={item.url || ""} />
              <p>{[item.event, item.venue].filter(Boolean).join(" · ")}</p>
              <CardUrlLinks links={item.links} />
            </article>
          ))}
        </div>
        {talksText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(talksText.trailer)}></span>}
      </div>

      <div id="grants" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker" set:html={renderInlineMarkdown(grantsText.kicker)}></p>
            <h2>{grantsText.header}</h2>
          </div>
        </div>
        {grantsText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(grantsText.intro)}></span>}
        <div class="stack">
          {featuredGrants.map((item) => (
            <article class="info-card compact">
              <p class="card-topline">
                {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
              </p>
              <CardTitleLink title={item.title || "Grant"} url={item.url || ""} />
              <p>{[item.role, item.sponsor].filter(Boolean).join(" · ")}</p>
              {item.amount && <p class="muted">{`${item.currency || ""} ${item.amount}`.trim()}</p>}
              <CardUrlLinks links={item.links} />
            </article>
          ))}
        </div>
        {grantsText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(grantsText.trailer)}></span>}
      </div>

      <div id="service" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker" set:html={renderInlineMarkdown(serviceText.kicker)}></p>
            <h2>{serviceText.header}</h2>
          </div>
          {serviceText.summary && <p class="section-summary" set:html={renderInlineMarkdown(serviceText.summary)}></p>}
        </div>
        {serviceText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(serviceText.intro)}></span>}
        <div class="stack">
          {featuredService.map((item) => (
            <article class="list-item compact">
              <p class="card-topline">
                {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
                {item.category ? ` · ${item.category}` : ""}
              </p>
              <CardTitleLink title={[item.role, item.organization].filter(Boolean).join(" · ") || "Service"} url={item.url || ""} />
              <p class="muted">{item.description}</p>
              <CardUrlLinks links={item.links} />
            </article>
          ))}
        </div>
        {serviceText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(serviceText.trailer)}></span>}
      </div>
    </section>

    <section id="misc" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(miscText.kicker)}></p>
          <h2>{miscText.header}</h2>
        </div>
        {miscText.summary && <p class="section-summary" set:html={renderInlineMarkdown(miscText.summary)}></p>}
      </div>
      {miscText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(miscText.intro)}></span>}
      <div class="card-grid">
        {featuredLinks.map((item) => (
          <article class="info-card">
            <p class="card-topline">{item.category || "link"}</p>
            <CardTitleLink title={item.label || "Link"} url={item.url || ""} />
            <p>{item.description}</p>
            <CardUrlLinks links={item.links} />
          </article>
        ))}
      </div>
      {miscText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(miscText.trailer)}></span>}
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .content-grid,
  .dual-grid,
  .tri-grid {
    display: grid;
    gap: 1.25rem;
  }

  .content-grid {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  }

  .dual-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tri-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .section-block,
  .section-intro,
  .list-panel {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .section-intro {
    display: grid;
    align-content: start;
    gap: 0.8rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2,
  .section-intro h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tag-row span {
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--line-strong);
    padding: 0.4rem 0.7rem;
    font-size: 0.88rem;
  }

  .stack {
    display: grid;
    gap: 0.85rem;
  }

  .student-grid {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .talk-grid {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .talk-card--featured {
    grid-column: 1 / -1;
  }

  .info-card {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .compact {
    padding: 0.9rem 0.95rem;
  }

  .info-card h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .content-grid,
    .dual-grid,
    .tri-grid {
      grid-template-columns: 1fr;
    }

    .student-grid {
      grid-template-columns: 1fr;
    }

    .talk-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      align-items: start;
      flex-direction: column;
    }

  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block,
    .section-intro,
    .list-panel {
      border-radius: 20px;
      padding: 1rem;
    }

  }
</style>
