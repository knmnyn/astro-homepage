---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import PublicationList from "../components/publication-list.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { primaryNavItems } from "../lib/site-navigation";
import { sitePath } from "../lib/site-path";

const profile = siteData.profile;

const bioLines = String(profile.bio_md || "")
  .split(/\n+/)
  .map((line) => line.trim())
  .filter(Boolean);

const publicationAreas = [...new Set(siteData.publications.map((item) => item.area).filter(Boolean))];
const featuredPublications = siteData.publications.slice(0, 6);
const currentTeaching = siteData.teaching.slice(0, 4);
const featuredStudents = siteData.students.filter((item) => item.status !== "archived").slice(0, 6);
const featuredTalks = siteData.talks.slice(0, 4);
const featuredGrants = siteData.grants.slice(0, 4);
const featuredSoftware = siteData.software.filter((item) => item.featured === "yes" || item.featured === "Yes");
const featuredService = siteData.service.slice(0, 4);
const featuredLinks = siteData.personalLinks.filter((item) => item.featured === "yes" || item.featured === "Yes");
const sectionNavItems = primaryNavItems;

const footerLinks = [
  {
    href: sitePath("publications/"),
    label: "Publications archive",
    title: "Browse the full publications page",
  },
];

const contactItems = [
  profile.email && { label: "Email", value: profile.email, href: `mailto:${profile.email}` },
  profile.cv_url && { label: "CV", value: "Curriculum Vitae", href: profile.cv_url },
  profile.office && { label: "Office", value: profile.office },
  profile.address && { label: "Address", value: profile.address },
].filter(Boolean);
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Homepage`}
  description={`Homepage for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Computer Science · Natural Language Processing · Information Retrieval"
      title={profile.name}
      headline={`${profile.title}${profile.role ? ` · ${profile.role}` : ""}`}
      body={bioLines}
      contacts={contactItems}
    />

    <SectionNav items={sectionNavItems} />

    <section id="research" class="content-grid">
      <div class="section-intro panel">
        <p class="section-kicker">Research</p>
        <h2>What this homepage is organized around</h2>
        <p>
          The sheet-driven site keeps the homepage compact while still reflecting the structure
          of the original website: research-oriented publications, current students, course
          history, software, service, talks, grants, and personal links.
        </p>
        <div class="tag-row">
          {publicationAreas.map((area) => <span>{area}</span>)}
        </div>
      </div>

      <PublicationList
        id="featured-publications"
        title="Featured publications"
        summary="A few representative items to keep the homepage readable. The full archive lives on the publications page."
        items={featuredPublications}
      />
    </section>

    <section id="teaching" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker">Teaching</p>
          <h2>Courses and facilitation</h2>
        </div>
        <p class="section-summary">
          Latest entries from the teaching sheet. <a class="inline-link" href={sitePath("teaching/")}>Full teaching page</a>.
        </p>
      </div>
      <div class="card-grid">
        {currentTeaching.map((item) => (
          <article class="info-card">
            <p class="card-topline">
              {item.academicYear || "n.d."}
              {item.term ? ` · ${item.term}` : ""}
            </p>
            <h3>
              {item.courseCode ? `${item.courseCode} ` : ""}
              {item.courseTitle || "Course"}
            </h3>
            <p>{[item.role, item.level, item.section].filter(Boolean).join(" · ")}</p>
            {item.notes && <p class="muted">{item.notes}</p>}
            {item.url && (
              <a class="inline-link" href={item.url} rel="noreferrer">
                Course page
              </a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="dual-grid">
      <div id="students" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker">Students</p>
            <h2>Current supervision snapshot</h2>
          </div>
        </div>
        <div class="stack">
          {featuredStudents.map((item) => (
            <article class="info-card compact">
              <p class="card-topline">
                {item.cohort || "n.d."}
                {item.level ? ` · ${item.level}` : ""}
              </p>
              <h3>{item.name}</h3>
              <p>{[item.role, item.status].filter(Boolean).join(" · ")}</p>
              {item.interests && <p class="muted">{item.interests}</p>}
            </article>
          ))}
        </div>
      </div>

      <div id="software" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker">Software</p>
            <h2>Featured tools and projects</h2>
          </div>
          <p class="section-summary">
            The full software inventory now lives on the <a class="inline-link" href={sitePath("research/")}>research page</a>.
          </p>
        </div>
        <div class="stack">
          {featuredSoftware.map((item) => (
            <article class="list-item compact">
              <h3>{item.name}</h3>
              <p>{item.description}</p>
              <p class="muted">{item.tags}</p>
              <div class="link-row">
                {item.repoUrl && (
                  <a class="inline-link" href={item.repoUrl} rel="noreferrer">
                    Repo
                  </a>
                )}
                {item.docsUrl && (
                  <a class="inline-link" href={item.docsUrl} rel="noreferrer">
                    Docs
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="tri-grid">
      <div id="talks" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker">Talks</p>
            <h2>Talk history</h2>
          </div>
        </div>
        <div class="stack">
          {featuredTalks.map((item) => (
            <article class="info-card compact">
              <p class="card-topline">
                {item.date || item.year || "n.d."}
                {item.event ? ` · ${item.event}` : ""}
              </p>
              <h3>{item.title || "Talk"}</h3>
              <p>{[item.venue, item.location].filter(Boolean).join(" · ")}</p>
            </article>
          ))}
        </div>
      </div>

      <div id="grants" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker">Grants</p>
            <h2>Research support</h2>
          </div>
        </div>
        <div class="stack">
          {featuredGrants.map((item) => (
            <article class="info-card compact">
              <p class="card-topline">
                {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
              </p>
              <h3>{item.title || "Grant"}</h3>
              <p>{[item.role, item.sponsor].filter(Boolean).join(" · ")}</p>
              {item.amount && <p class="muted">{`${item.currency || ""} ${item.amount}`.trim()}</p>}
            </article>
          ))}
        </div>
      </div>

      <div id="service" class="panel section-block">
        <div class="section-header">
          <div>
            <p class="section-kicker">Service</p>
            <h2>Professional and scholarly service</h2>
          </div>
        <p class="section-summary">
          Selected highlights from the service sheet. <a class="inline-link" href={sitePath("misc/")}>Full service archive</a>.
        </p>
        </div>
        <div class="stack">
          {featuredService.map((item) => (
            <article class="list-item compact">
              <p class="card-topline">
                {[item.startYear, item.endYear].filter(Boolean).join(" - ") || "n.d."}
                {item.category ? ` · ${item.category}` : ""}
              </p>
              <h3>{[item.role, item.organization].filter(Boolean).join(" · ")}</h3>
              <p class="muted">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="misc" class="panel section-block">
      <div class="section-header">
        <div>
          <p class="section-kicker">Misc</p>
          <h2>Personal links and extras</h2>
        </div>
        <p class="section-summary">
          Shortcuts carried over from the old personal page. <a class="inline-link" href={sitePath("misc/")}>Open the full archive</a>.
        </p>
      </div>
      <div class="card-grid">
        {featuredLinks.map((item) => (
          <article class="info-card">
            <p class="card-topline">{item.category || "link"}</p>
            <h3>
              {item.url ? (
                <a href={item.url} rel="noreferrer">
                  {item.label || "Link"}
                </a>
              ) : (
                item.label || "Link"
              )}
            </h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .content-grid,
  .dual-grid,
  .tri-grid {
    display: grid;
    gap: 1.25rem;
  }

  .content-grid {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  }

  .dual-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tri-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .section-block,
  .section-intro,
  .list-panel {
    border-radius: 26px;
    padding: 1.25rem;
  }

  .section-intro {
    display: grid;
    align-content: start;
    gap: 0.8rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-header h2,
  .section-intro h2 {
    margin: 0.3rem 0 0;
    letter-spacing: -0.03em;
    font-size: clamp(1.3rem, 2vw, 2rem);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tag-row span {
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--line-strong);
    padding: 0.4rem 0.7rem;
    font-size: 0.88rem;
  }

  .stack {
    display: grid;
    gap: 0.85rem;
  }

  .info-card {
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--panel-contrast);
    padding: 1rem 1rem 0.95rem;
    box-shadow: var(--shadow-soft);
  }

  .compact {
    padding: 0.9rem 0.95rem;
  }

  .info-card h3 {
    margin: 0.35rem 0 0.3rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .muted {
    color: var(--muted);
  }

  .inline-link {
    display: inline-flex;
    margin-top: 0.6rem;
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .inline-link:hover,
  .action-link:hover {
    color: var(--accent-2);
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.6rem;
  }

  @media (max-width: 980px) {
    .content-grid,
    .dual-grid,
    .tri-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      align-items: start;
      flex-direction: column;
    }

  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }

    .section-block,
    .section-intro,
    .list-panel {
      border-radius: 20px;
      padding: 1rem;
    }

  }
</style>
