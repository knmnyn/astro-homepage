---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/hero-section.astro";
import SectionNav from "../components/section-nav.astro";
import PublicationList from "../components/publication-list.astro";
import SiteFooter from "../components/site-footer.astro";
import { siteData } from "../lib/site-data";
import { getNavSectionText, primaryNavItems } from "../lib/site-navigation";
import { groupPublicationsBySectionWithSheet } from "../lib/publication-groups.js";
import { sitePath } from "../lib/site-path";
import { renderInlineMarkdown } from "../lib/inline-markdown.js";
import { buildSheetMetrics, collectMetricFieldValues } from "../lib/sheet-metrics.js";

const profile = siteData.profile;
const publicationMetrics = buildSheetMetrics(siteData.sources.publications);
const publicationAreaLabels = collectMetricFieldValues(siteData.sources.publications.records, "Area");
const featuredPublications = siteData.publications.slice(0, 8);
const archivePublications = siteData.publications;
const publicationGroups = groupPublicationsBySectionWithSheet(archivePublications, siteData.sources.publications);
const publicationsText = getNavSectionText("publications", { kicker: "Publications" });
const publicationAreaMetric = publicationMetrics.find((metric) => metric.kind === "enum" && metric.fieldKey === "area") || null;

const navItems = primaryNavItems;

const footerLinks = [
  {
    href: sitePath(""),
    label: "Back home",
    title: "Return to the homepage",
  },
  {
    href: sitePath("research/"),
    label: "Research page",
    title: "Browse the research overview",
  },
];
---

<Layout
  title={`${profile.name || "Min-Yen Kan"} | Publications`}
  description={`Publications archive for ${profile.name || "Min-Yen Kan"}, powered by Astro and Google Sheets content.`}
>
  <main class="page-shell">
    <HeroSection
      eyebrow="Publications archive"
      title={profile.name || "Min-Yen Kan"}
      headline="A complete list of publications from the sheet, with featured items at the top and the full archive below."
      tags={[
        `${siteData.publications.length} publications`,
        `${publicationAreaLabels.length || "No"} areas`,
        profile.title,
      ].filter(Boolean)}
      stats={[
        {
          label: "Featured",
          value: featuredPublications.length,
          text: "Curated highlights to orient readers quickly.",
        },
        {
          label: "Research areas",
          value: publicationAreaMetric?.values.length || "—",
          text: publicationAreaLabels.join(" · ") || "Areas appear here as the sheet grows.",
          accent: true,
        },
      ]}
    />

    <SectionNav items={navItems} />

    <PublicationList
      id="featured"
      title={publicationsText.header}
      summary={publicationsText.summary}
      kicker={publicationsText.kicker}
      intro={publicationsText.intro}
      trailer={publicationsText.trailer}
      items={featuredPublications}
      sheet={siteData.sources.publications}
      showExtras={true}
    />

    <section id="archive" class="panel section-block archive-block">
      <div class="section-header">
        <div>
          <p class="section-kicker" set:html={renderInlineMarkdown(publicationsText.kicker)}></p>
          <h2>{publicationsText.header}</h2>
        </div>
        <div class="section-header-aside">
          {publicationsText.summary && <p class="section-summary" set:html={renderInlineMarkdown(publicationsText.summary)}></p>}
          {publicationsText.intro && <span class="section-copy section-copy--intro" set:html={renderInlineMarkdown(publicationsText.intro)}></span>}
        </div>
      </div>

      <div class="publication-groups">
        {publicationGroups.map((group) => (
          <PublicationList
            id={`archive-${group.label.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") || "other"}`}
            title={group.label}
            items={group.items}
            sheet={group.sheet}
            showExtras={true}
            masonryGrid={true}
          />
        ))}
      </div>

      {publicationsText.trailer && <span class="section-copy section-copy--trailer" set:html={renderInlineMarkdown(publicationsText.trailer)}></span>}
    </section>

    <SiteFooter links={footerLinks} />
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1140px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .archive-block {
    display: grid;
    gap: 1rem;
    border-radius: 26px;
    padding: 1.25rem;
  }

  .archive-block .section-header-aside {
    display: grid;
    gap: 0.6rem;
    justify-items: end;
  }

  .publication-groups {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 980px) {
    .archive-block .section-header-aside {
      justify-items: start;
    }
  }

  @media (max-width: 980px) {
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1140px);
      padding-top: 1rem;
    }
  }
</style>
