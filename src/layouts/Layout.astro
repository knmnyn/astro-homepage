---
const {
  title = "Min-Yen Kan",
  description = "Min-Yen Kan's homepage, powered by Astro and Google Sheets content.",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			(() => {
				const storageKey = "astro-homepage-theme";
				const fontScaleKey = "astro-homepage-font-scale";
				const root = document.documentElement;
				const media = window.matchMedia("(prefers-color-scheme: dark)");

				const getStoredChoice = () => {
					try {
						const value = window.localStorage.getItem(storageKey);
						return value === "light" || value === "dark" || value === "auto" ? value : "auto";
					} catch {
						return "auto";
					}
				};

				const getStoredFontScale = () => {
					try {
						const value = window.localStorage.getItem(fontScaleKey);
						return value === "80" || value === "100" || value === "120" ? value : "100";
					} catch {
						return "100";
					}
				};

				const resolveTheme = (choice) =>
					choice === "auto" ? (media.matches ? "dark" : "light") : choice;

				const applyTheme = (choice) => {
					const theme = resolveTheme(choice);
					root.setAttribute("data-theme-mode", choice);
					root.setAttribute("data-theme", theme);
					root.style.colorScheme = theme;
					for (const button of document.querySelectorAll("[data-theme-choice]")) {
						button.setAttribute("aria-pressed", String(button.dataset.themeChoice === choice));
					}
				};

				const applyFontScale = (choice) => {
					const scale = getStoredFontScale();
					const nextScale = choice === "80" || choice === "100" || choice === "120" ? choice : scale;
					root.dataset.fontScale = nextScale;
					root.style.fontSize = `${nextScale}%`;
					for (const select of document.querySelectorAll("[data-font-scale-choice]")) {
						select.value = nextScale;
					}
				};

				const storedChoice = getStoredChoice();
				applyTheme(storedChoice);
				applyFontScale(getStoredFontScale());

				window.addEventListener("DOMContentLoaded", () => {
					for (const button of document.querySelectorAll("[data-theme-choice]")) {
						button.addEventListener("click", () => {
							const choice = button.dataset.themeChoice || "auto";
							try {
								window.localStorage.setItem(storageKey, choice);
							} catch {
								// Ignore storage failures and keep the interaction functional.
							}
							applyTheme(choice);
						});
					}

					for (const select of document.querySelectorAll("[data-font-scale-choice]")) {
						select.addEventListener("change", () => {
							const choice = select.value;
							try {
								window.localStorage.setItem(fontScaleKey, choice);
							} catch {
								// Ignore storage failures and keep the interaction functional.
							}
							applyFontScale(choice);
						});
					}

					applyTheme(getStoredChoice());
					applyFontScale(getStoredFontScale());
				});

				media.addEventListener("change", () => {
					if (getStoredChoice() === "auto") {
						applyTheme("auto");
					}
				});
			})();
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--nav-panel: rgba(255, 255, 255, 0.92);
		--nav-border: rgba(0, 57, 166, 0.18);
		--nav-shadow: 0 18px 40px rgba(23, 32, 42, 0.12);
		--nav-chip: rgba(255, 255, 255, 0.76);
		--bg: #f3f0ea;
		--bg-alt: #f8f4ee;
		--bg-accent: rgba(0, 57, 166, 0.08);
		--bg-accent-2: rgba(238, 119, 0, 0.08);
		--panel: rgba(255, 255, 255, 0.84);
		--panel-strong: #ffffff;
		--panel-contrast: rgba(255, 255, 255, 0.62);
		--text: #17202a;
		--muted: #4f5b67;
		--line: rgba(0, 57, 166, 0.12);
		--line-strong: rgba(0, 57, 166, 0.18);
		--accent: #0039a6;
		--accent-2: #ee7700;
		--accent-3: #00544c;
		--accent-soft: rgba(0, 57, 166, 0.1);
		--accent-soft-strong: rgba(238, 119, 0, 0.14);
		--shadow: 0 28px 64px rgba(0, 57, 166, 0.08);
		--shadow-soft: 0 16px 36px rgba(23, 32, 42, 0.08);
		--control-bg: rgba(255, 255, 255, 0.88);
		--control-active: #0039a6;
		--control-active-text: #ffffff;
	}

	:root[data-theme="dark"] {
		color-scheme: dark;
		--nav-panel: rgba(10, 17, 29, 0.92);
		--nav-border: rgba(142, 180, 255, 0.22);
		--nav-shadow: 0 18px 44px rgba(1, 8, 18, 0.48);
		--nav-chip: rgba(14, 23, 39, 0.84);
		--bg: #09111d;
		--bg-alt: #0e1727;
		--bg-accent: rgba(0, 57, 166, 0.22);
		--bg-accent-2: rgba(238, 119, 0, 0.16);
		--panel: rgba(12, 20, 33, 0.82);
		--panel-strong: rgba(16, 27, 43, 0.95);
		--panel-contrast: rgba(16, 27, 43, 0.72);
		--text: #eef4fb;
		--muted: #aab8c8;
		--line: rgba(112, 146, 206, 0.18);
		--line-strong: rgba(112, 146, 206, 0.28);
		--accent: #8eb4ff;
		--accent-2: #ffb15e;
		--accent-3: #7bd8c2;
		--accent-soft: rgba(142, 180, 255, 0.12);
		--accent-soft-strong: rgba(255, 177, 94, 0.14);
		--shadow: 0 28px 64px rgba(1, 8, 18, 0.55);
		--shadow-soft: 0 16px 40px rgba(1, 8, 18, 0.32);
		--control-bg: rgba(14, 23, 39, 0.94);
		--control-active: #8eb4ff;
		--control-active-text: #08111c;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		box-sizing: border-box;
		font-size: 100%;
		background:
			radial-gradient(circle at top left, var(--bg-accent-2), transparent 28%),
			radial-gradient(circle at top right, var(--bg-accent), transparent 32%),
			linear-gradient(180deg, var(--bg) 0%, var(--bg-alt) 100%);
		color: var(--text);
		font-family:
			"IBM Plex Sans", "Avenir Next", "Segoe UI", system-ui, sans-serif;
	}

	body {
		padding-top: 5.4rem;
	}

	a {
		color: inherit;
	}

	button {
		font: inherit;
	}

	::selection {
		background: color-mix(in srgb, var(--accent) 24%, transparent);
		color: var(--text);
	}

	:where(.hero, .panel, .section-block, .section-intro, .publication-list) {
		scroll-margin-top: 6.5rem;
	}

	:focus-visible {
		outline: 2px solid var(--accent-2);
		outline-offset: 3px;
	}

	@media (max-width: 720px) {
		body {
			padding-top: 4.9rem;
		}
	}
</style>
